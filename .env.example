# Serper API key for website resolution and age verification
SERPER_API_KEY=your_serper_api_key_here

# Google Gemini API key for AI institution summaries
GEMINI_API_KEY=your_gemini_api_key_here

# Set to false to skip Gemini entirely (uses local report parser)
USE_GEMINI=true

# Gemini model (default: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# Number of qualified institutions to collect per pipeline run
TARGET_QUALIFIED=20

# Path to AISHE discovery data
AISHE_DATA_PATH=data/AISHE.xlsx

# Frontend API base URL (optional, defaults to /api proxy in dev)
VITE_API_BASE_URL=http://127.0.0.1:8000
